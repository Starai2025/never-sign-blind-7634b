# ============================================================
# Never Sign Blind™ — Environment Variables
# Copy this to .env for local dev. NEVER commit .env.
# ============================================================

# ── Admin ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace_with_long_random_string
NOTIFICATION_EMAIL=thegiftedbystarr@gmail.com

# ── Email (Resend) ────────────────────────────────────────────
# Get from: resend.com → API Keys
# Leave blank in testing → auto-uses Ethereal (fake SMTP, browser preview)
RESEND_API_KEY=
RESEND_FROM_EMAIL=starr@neversignblind.com

# ── AI Review Engine (Anthropic) ─────────────────────────────
# Get from: console.anthropic.com → API Keys
# Leave blank in testing → auto-uses mock review JSON
ANTHROPIC_API_KEY=

# ── Payments (Stripe) ────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Stripe Payment Links ─────────────────────────────────────
# Create at: Stripe → Payment Links
# Add metadata: { "tier": "quick" } etc.
# Set success_url to: https://never-sign-blind.netlify.app/intake.html?session={CHECKOUT_SESSION_ID}&tier=quick
STRIPE_LINK_99=https://buy.stripe.com/test_replace_quick
STRIPE_LINK_299=https://buy.stripe.com/test_replace_full
STRIPE_LINK_499=https://buy.stripe.com/test_replace_rush
